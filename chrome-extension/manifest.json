{
  "manifest_version": 3,
  "name": "Talli Time Tracker",
  "version": "1.0.0",
  "description": "Quick time tracking and expense entry for Talli",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://*.up.railway.app/*", "http://localhost/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
